<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="12.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<KSPPath Condition="'$(KSPPath)' == ''">C:\Program Files (x86)\Steam\steamapps\common\Kerbal Space Program</KSPPath>
		<KSPManagedPath>$(KSPPath)\KSP_x64_Data\Managed</KSPManagedPath>
		<HullcamVDSPath>$(KSPPath)\GameData\HullCameraVDS\Plugins\HullcamVDSContinued.dll</HullcamVDSPath>
	</PropertyGroup>
</Project>
