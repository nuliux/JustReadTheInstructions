  <PropertyGroup>
    <PreBuildEvent>
			@echo ========================================
			@echo Cleaning Distribution folder...
			@echo ========================================

			if exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Plugins\" (
			RD /S /Q "$(ProjectDir)Distribution\GameData\$(TargetName)\Plugins\"
			)
			MD "$(ProjectDir)Distribution\GameData\$(TargetName)\Plugins\"

			if exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Textures\" (
			RD /S /Q "$(ProjectDir)Distribution\GameData\$(TargetName)\Textures\"
			)
			MD "$(ProjectDir)Distribution\GameData\$(TargetName)\Textures\"

			if exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\" (
			RD /S /Q "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\"
			)
			MD "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\"

			@echo Distribution folder prepared.
		</PreBuildEvent>
  </PropertyGroup>
  <PropertyGroup>
    <PostBuildEvent>
			@echo ========================================
			@echo Copying mod to Distribution folder...
			@echo ========================================

			@echo Copying DLL and PDB...
			xcopy /Y "$(TargetDir)$(TargetFileName)" "$(ProjectDir)Distribution\GameData\$(TargetName)\Plugins\"
			xcopy /Y "$(TargetDir)$(TargetName).pdb" "$(ProjectDir)Distribution\GameData\$(TargetName)\Plugins\"

			@echo Copying toolbar icon...
			if exist "$(ProjectDir)Assets\Textures\icon.png" (
			xcopy /Y "$(ProjectDir)Assets\Textures\icon.png" "$(ProjectDir)Distribution\GameData\$(TargetName)\Textures\"
			) else (
			@echo WARNING: Missing icon file: $(ProjectDir)Assets\Textures\icon.png
			)

			@echo Copying web app...
			if exist "$(ProjectDir)Assets\Web\" (
			xcopy /E /Y "$(ProjectDir)Assets\Web\*" "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\"
			) else (
			@echo ERROR: Missing web folder: $(ProjectDir)Assets\Web\
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\index.html" (
			@echo ERROR: index.html missing after copy
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\viewer.html" (
			@echo ERROR: viewer.html missing after copy
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\css\styles.css" (
			@echo ERROR: css\styles.css missing after copy
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\js\main.js" (
			@echo ERROR: js\main.js missing after copy
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\js\viewer.js" (
			@echo ERROR: js\viewer.js missing after copy
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\images\los.png" (
			@echo ERROR: images\los.png missing after copy
			exit /b 1
			)

			if not exist "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\recordings\" (
			MD "$(ProjectDir)Distribution\GameData\$(TargetName)\Web\recordings\"
			)

			@echo Copying default settings...
			if exist "$(ProjectDir)Assets\settings.cfg" (
			xcopy /Y "$(ProjectDir)Assets\settings.cfg" "$(ProjectDir)Distribution\GameData\$(TargetName)\"
			) else (
			@echo WARNING: Missing settings file: $(ProjectDir)Assets\settings.cfg
			)

			@echo Build complete! Mod is in Distribution folder.
			@echo ========================================
		</PostBuildEvent>
  </PropertyGroup>
